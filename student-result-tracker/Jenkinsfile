pipeline {
    agent any
    
    environment {
        // Environment variables for Docker Hub credentials and image details
        DOCKER_HUB_CREDENTIALS_ID = 'dockerhub-credentials'
        DOCKER_USER = credentials('DOCKER_USER') // Placeholder for Docker Hub username
        DOCKER_PASS = credentials('DOCKER_PASS') // Placeholder for Docker Hub password
        IMAGE_NAME = "student-tracker"
        IMAGE_TAG = "latest"
        FULL_IMAGE_NAME = "${DOCKER_USER}/${IMAGE_NAME}:${IMAGE_TAG}"
    }

    stages {
        // Stage 1: Build the Docker image
        stage('Build') {
            steps {
                echo "Building the Docker image..."
                // Build the image using the Dockerfile in the student-result-tracker directory
                sh "docker build -t ${IMAGE_NAME}:${IMAGE_TAG} ./student-result-tracker"
            }
        }
        
        // Stage 2: Test the application locally
        stage('Test') {
            steps {
                echo "Testing the application..."
                // Run the container in detached mode to test it
                sh "docker run -d -p 5000:5000 --name test-app ${IMAGE_NAME}:${IMAGE_TAG}"
                
                // Wait for the application to start
                sleep 5
                
                // Run a curl command to check if the /students endpoint is responsive
                sh "curl -f http://localhost:5000/students"
                
                // Clean up the test container
                sh "docker stop test-app"
                sh "docker rm test-app"
            }
        }
        
        // Stage 3: Push the image to Docker Hub
        stage('Push') {
            steps {
                echo "Pushing the image to Docker Hub..."
                // Login to Docker Hub using the provided credentials
                sh "echo ${DOCKER_PASS} | docker login -u ${DOCKER_USER} --password-stdin"
                
                // Tag the local image with the Docker Hub username repository
                sh "docker tag ${IMAGE_NAME}:${IMAGE_TAG} ${FULL_IMAGE_NAME}"
                
                // Push the image to the repository
                sh "docker push ${FULL_IMAGE_NAME}"
                
                // Logout to clear credentials
                sh "docker logout"
            }
        }
    }
    
    // Post actions executed after the pipeline completes
    post {
        success {
            echo "Pipeline successful!"
        }
        failure {
            echo "Pipeline failed!"
            // Ensure cleanup in case of failure during testing
            sh "docker rm -f test-app || true"
        }
    }
}
